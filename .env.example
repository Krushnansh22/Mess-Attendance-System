# ── Mess Attendance System — Environment Variables ──────────────────────────
# Copy this file to .env and fill in real values before starting the server.

# The secret encoded in your printed QR code (e.g., MESS_LOCATION_01_SECURE_KEY)
MESS_QR_SECRET_KEY=MESS_LOCATION_01_SECURE_KEY

# Base64-encoded Google Service Account JSON key
# Generate with: base64 -w 0 service_account.json
GOOGLE_SERVICE_ACCOUNT_JSON=<base64-encoded-service-account-json>

# Google Sheets document ID (from the URL: /spreadsheets/d/<ID>/edit)
GOOGLE_SHEET_ID=<your-google-sheet-id>

# Random 256-bit secret for signing JWT tokens
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=<random-256-bit-hex-secret>

# Passcode required when registering an admin account
ADMIN_PASSCODE=<secure-admin-registration-passcode>

# ── Optional GPS enforcement ──────────────────────────────────────────────────
# Set GPS_ENABLED=true to require students to be physically at the mess
GPS_ENABLED=false

# Mess GPS anchor point (required if GPS_ENABLED=true)
MESS_LATITUDE=17.6868
MESS_LONGITUDE=75.9104

# Allowed radius in metres from the anchor point (default: 50)
MESS_RADIUS_METRES=50
